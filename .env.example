API_KEY=sk-ant-...
# API_BASE_URL=                 # Custom base URL (default: https://api.anthropic.com)

# Model
# DEFAULT_MODEL=claude-sonnet-4-20250514

# Scheduler
# CRON_EXPRESSION=*/10 * * * *  # How often the agent checks for tasks (default: every 10 min)

# Workspace
# WORK_DIR=.                    # Working directory for agent tasks

# Self-evolution
# SELF_EVOLVE_ENABLED=false     # Enable self-modification capability
# SELF_EVOLVE_BRANCH=evolve     # Git branch name for evolution attempts

# System prompt (override the default)
# DEFAULT_SYSTEM_PROMPT=You are an autonomous AI agent. Complete tasks thoroughly and report results.
